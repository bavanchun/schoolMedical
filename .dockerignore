# Docker ignore file to exclude unnecessary files from build context
target/
!target/*.jar
!target/lib/
.git
.gitignore
README.md
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.DS_Store
.vscode/
.idea/
*.iml
*.iws
*.ipr
logs/
*.log

